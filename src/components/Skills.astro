---
import type { UI, Lang } from '../i18n/utils';
interface Props {
  t: UI[Lang]['skills'];
}
const { t } = Astro.props;
---

<section class="py-xl max-w-container-max mx-auto px-gutter" id="skills">
  <div class="text-center mb-16">
    <h2 class="text-headline-lg">{t.headline}</h2>
    <p class="text-on-surface-variant mt-4">{t.body}</p>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4">
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.frontend}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">React</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Vue</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Next.js</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">TypeScript</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">HTML</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">CSS</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Tailwind CSS</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">JavaScript</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.backend}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Node.js</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Express.js</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">NestJS</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.databases}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">PostgreSQL</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">MySQL</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.cloud}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">AWS</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Azure</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Cloudflare</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.architecture}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">SSR/SSG</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Multi-tenant SaaS</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">SPA</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.tools}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">CI/CD</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Git</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Electron</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Shopify</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">WordPress</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">GitHub Actions</span>
      </div>
    </div>
    <div class="space-y-3">
      <h4 class="text-label-md text-primary uppercase tracking-widest">{t.categories.aiTools}</h4>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Claude Code</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Cursor</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">Codex</span>
        <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-on-surface text-label-sm">OpenCode</span>
      </div>
    </div>
  </div>
</section>
